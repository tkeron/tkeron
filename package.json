{
  "name": "tkeron",
  "version": "5.3.0",
  "description": "CLI build tool for vanilla web development with TypeScript.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
